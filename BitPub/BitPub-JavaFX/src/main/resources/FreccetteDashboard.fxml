    <Label text="Partita Freccette (501)" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #333333;" />

    <HBox alignment="CENTER" spacing="80.0">

        <VBox alignment="CENTER" spacing="15.0">
            <Label fx:id="lblGiocatore1" text="Giocatore 1" style="-fx-font-size: 20px;" />
